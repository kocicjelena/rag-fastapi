{
  "servers": {
    "mcpServers": {
     "Neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/mcp",
      "headers": {
        "Authorization": "Bearer apikey"
      }
    }
  },
    "myNodeServer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://....?sslmode=require"
      ]
    },
    "myPythonServer": {
      "command": "/path/to/venv/bin/python",
      "args": [
        "/absolute/path/to/your/server.py"
      ],
      "env": {
        "API_KEY": "..."
      }
    }
  }
}
